# Copy this file to .env and fill in your values
# Never commit .env to version control

# Smartlead API key — found at: app.smartlead.ai → Settings → API
SMARTLEAD_API_KEY=your_smartlead_api_key_here

# Aimfox API key — found at: app.aimfox.com → Settings → Integrations → API Keys
AIMFOX_API_KEY=your_aimfox_api_key_here

# The string to match against campaign names (case-insensitive)
CLIENT_FILTER=FEAAM
